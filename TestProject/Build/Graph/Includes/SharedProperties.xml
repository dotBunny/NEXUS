<?xml version='1.0' ?>
<BuildGraph xmlns="http://www.epicgames.com/BuildGraph" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.epicgames.com/BuildGraph ../Schema.xsd" >
	<!-- Path To Epic's BuildGraphs -->
	<Property Name="EpicGraphPath" Value="../../../Engine/Build/Graph/" />
	
	<!-- Fake local build machine -->
	<Do If="!$(IsHordeEnv)">
		<Property Name="IsBuildMachine" Value="true" />
	</Do>

	<!-- Create our stubs for simplified labels in UGS, these will get added to the Other category in Horde -->
	<Property Name="EditorStatusAggregate" Value="" />
	<Property Name="ContentStatusAggregate" Value="" />
	<Property Name="BuildStatusAggregate" Value="" />
	<Property Name="TestStatusAggregate" Value="" />
	<Property Name="PublishStatusAggregate" Value="" />
	
</BuildGraph>
