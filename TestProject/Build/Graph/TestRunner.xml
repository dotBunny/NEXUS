<?xml version='1.0' ?>
<BuildGraph xmlns="http://www.epicgames.com/BuildGraph" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.epicgames.com/BuildGraph ../Schema.xsd" >
    
    <Include Script="Includes/CompositeGlobals.xml" />
    <Include Script="Includes/K9Properties.xml" />    
    <Option Name="TestPackageLabel" DefaultValue="" Description="Label that should be used or updated in Horde/GitHub"/>

    <!-- Should we run an editor boot test? -->    
    <Option Name="WithEditorBootTest" DefaultValue="true" Restrict="true|false" Description="Should we be check that the Editor boots?"/>
    <Do If="'$(WithEditorBootTest)' != 'false'" >
        <Property Name="WithWin64Editor" Value="true" />
        <Property Name="EditorBootTest" Value="true" />              
    </Do>
    
    <!-- Should we run unit tests in the editor? -->
    <Option Name="WithEditorUnitTests" DefaultValue="false" Restrict="true|false" Description="Should we be running Unit Tests in the Editor?"/>
    <Do If="'$(WithEditorUnitTests)' != 'false'" >
        <Property Name="WithWin64Editor" Value="true" />
        <Property Name="EditorTestList" Value="$(EditorTestList)+UE.EditorAutomation(RunTest=NEXUS.UnitTests)" />        
    </Do>

    <!-- Should we run performance tests in the editor? -->
    <Option Name="WithEditorPerformanceTests" DefaultValue="false" Restrict="true|false" Description="Should we be running Performance Tests in the Editor?"/>
    <Do If="'$(WithEditorPerformanceTests)' != 'false'" >
        <Property Name="WithWin64Editor" Value="true" />
        <Property Name="EditorTestList" Value="$(EditorTestList)+UE.EditorAutomation(RunTest=NEXUS.PerfTests)" />        
    </Do>

    <!-- Should we run functional tests in the editor? -->
    <Option Name="WithEditorFunctionalTests" DefaultValue="false" Restrict="true|false" Description="Should we be running Functional Tests in the Editor?"/>
    <Do If="'$(WithEditorFunctionalTests)' != 'false'" >
        <Property Name="WithWin64Editor" Value="true" />
        <Property Name="EditorTestList" Value="$(EditorTestList)+UE.EditorAutomation(RunTest=Project.)" />        
    </Do>

    <Option Name="WithGameBootTest" DefaultValue="false" Restrict="true|false" Description="Should we be check the game boots?"/>
    <Do If="'$(WithGameBootTest)' != 'false'" >
        <Property Name="WithWin64" Value="true" />
        <Property Name="TargetBootTest" Value="true" />        
    </Do>

    <!-- INCLUDE EPICS MAIN TASK -->
    <Include Script="../../../../Engine/Build/Graph/Tasks/BuildAndTestProject.xml" />

    <Aggregate Name="TestPackage" Requires="BuildAndTest $(ProjectName)"/>
     
     <Do If="'$(TestPackageLabel)' != ''" >
        <Label Category="Tests" Name="$(TestPackageLabel)" Requires="BuildAndTest $(ProjectName)" UgsBadge="$(TestPackageLabel)" />
     </Do>

</BuildGraph>