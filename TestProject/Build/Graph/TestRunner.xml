<?xml version='1.0' ?>
<BuildGraph xmlns="http://www.epicgames.com/BuildGraph" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.epicgames.com/BuildGraph ../Schema.xsd" >
      
    
    <Include Script="Includes/CompositeGlobals.xml" />
    <Include Script="Includes/K9Properties.xml" />

    <Property Name="TestPackageLabel" Value="" />
    <Property Name="TestPackageAggregate" Value="" />
    
    <Option Name="WithTestConfiguration" DefaultValue="EditorBootTest" Description="What known configuration should we use (EditorBootTest, EditorUnitTests, EditorPerformanceTests, EditorFunctionalTests, GameBootTest)?" />
    
    <Property Name="PublishAgentType" Value="Win64" />
	<Property Name="PublishAgentType" Value="Incremental$(PublishAgentType)" If="$(UseIncrementalAgents)" />
    
    <Property Name="GraphPrefix" Value="OnlyTest" />

    <!-- EDITOR BOOT TEST -->    
    <Do If="'$(WithTestConfiguration)' == 'EditorBootTest'" >        
        <Property Name="WithWin64Editor" Value="true" />

        <Property Name="SkipCook" Value="true" />
        <Property Name="SkipPackage" Value="true" />
        <Property Name="SkipPublish" Value="true" />

        <Property Name="EditorBootTest" Value="true" />
        <Property Name="TargetBootTest" Value="false" />
        <Property Name="CookedEditorBootTest" Value="false" />
                
        <Property Name="TestPackageLabel" Value="BootTest Editor Win64" />      
    </Do>


    <!-- EDITOR UNIT TESTS -->    
    <Do If="'$(WithTestConfiguration)' == 'EditorUnitTests'" >
        <Property Name="WithWin64Editor" Value="true" />

        <Property Name="SkipCook" Value="true" />
        <Property Name="SkipPackage" Value="true" />
        <Property Name="SkipPublish" Value="true" />

        <Property Name="EditorBootTest" Value="false" />
        <Property Name="TargetBootTest" Value="false" />
        <Property Name="CookedEditorBootTest" Value="false" />
          
        <Property Name="DefaultEditorTestList" Value="UE.EditorAutomation(RunTest=NEXUS.UnitTests)" />
        <Property Name="TestPackageLabel" Value="UnitTests Editor Win64" />
    </Do>
    
    <!-- EDITOR PERFORMANCE TESTS -->    
    <Do If="'$(WithTestConfiguration)' == 'EditorPerformanceTests'" >
        <Property Name="WithWin64Editor" Value="true" />

        <Property Name="SkipCook" Value="true" />
        <Property Name="SkipPackage" Value="true" />
        <Property Name="SkipPublish" Value="true" />

        <Property Name="EditorBootTest" Value="false" />
        <Property Name="TargetBootTest" Value="false" />
        <Property Name="CookedEditorBootTest" Value="false" />
        
        <Property Name="DefaultEditorTestList" Value="UE.EditorAutomation(RunTest=NEXUS.PerfTests)" />
        <Property Name="TestPackageLabel" Value="PerfTests Editor Win64" />
    </Do>
    
    <!-- EDITOR FUNCTIONAL TESTS -->
    <Do If="'$(WithTestConfiguration)' == 'EditorFunctionalTests'" >
        <Property Name="WithWin64Editor" Value="true" />  
        
        <Property Name="SkipCook" Value="true" />
        <Property Name="SkipPackage" Value="true" />
        <Property Name="SkipPublish" Value="true" />

        <Property Name="EditorBootTest" Value="false" />
        <Property Name="TargetBootTest" Value="false" />
        <Property Name="CookedEditorBootTest" Value="false" />

        <Property Name="DefaultEditorTestList" Value="UE.EditorAutomation(RunTest=Project.)" />
        <Property Name="TestPackageLabel" Value="FuncTests Editor Win64" />        
    </Do>

    <!-- GAME BOOT TEST -->    
    <Do If="'$(WithTestConfiguration)' == 'GameBootTest'" >
        <Property Name="EditorBootTest" Value="false" />
        <Property Name="TargetBootTest" Value="true" />
        <Property Name="CookedEditorBootTest" Value="false" />
        <Property Name="GraphPrefix" Value="BuildAndTest" />

        <Property Name="WithWin64" Value="true" />
        <Property Name="WithWin64Editor" Value="true" />

        <Property Name="TestPackageLabel" Value="BootTest Game Win64" />      
    </Do>

    <!-- INCLUDE EPICS MAIN TASK -->
    <Include Script="../../../../Engine/Build/Graph/Tasks/BuildAndTestProject.xml" />


    <Aggregate Name="TestPackageWait" Requires="$(GraphPrefix) $(ProjectName)"/>


    <!-- SETUP OUR PUBLISHING OF GIT COMMIT STATUS -->
    <Property Name="UpdateGitHubStatus" Value="false" />
    <Property Name="UpdateGitHubStatus" Value="true" If="'$(UE_HORDE_JOBID)' != ''" />
    <Do If="$(UpdateGitHubStatus)">
        <Property Name="TestPackageAggregate" Value="$(TestPackageAggregate);GitHub Commit Status"/>
    </Do>
    
    <Agent Name="Publish Updates" Type="$(PublishAgentType)">  
        
        <!-- GITHUB COMMIT STATUS -->
        <Do If="$(UpdateGitHubStatus)">
            <Property Name="GitHubTestState" Value="failure" />
            <Log Message="Updating GitHub Commit State ..." />                
            <Node Name="GitHub Determine Status" Requires="TestPackageWait">
                <Log Message="Tests were successful, setting success state." />
                <Property Name="GitHubTestState" Value="success" />
            </Node>
            <Node Name="GitHub Commit Status" After="GitHub Determine Status">
                <Horde-GetSecrets File="$(RootDir)\Staging\github.k9.tmp" Text="{{nexus.github-token}}"/>
                
                <!-- START: Get & Compile K9 Tooling -->			
                <!-- If we dont have the source, get it, if we do update it. -->
                <Do If="Exists('$(K9Checkout)/')">
                    <Log Message="Updating K9 ..." />
                    <Git-Clone Dir="$(K9Checkout)" Branch="origin/main"/>		
                </Do>			
                <Do If="!Exists('$(K9Checkout)/')">
                    <Log Message="Cloning K9 ..." />
                    <Git-Clone Dir="$(K9Checkout)" Remote="$(K9Repository)" Branch="origin/main" />										
                </Do>
                
                <Log Message="Compiling Used K9 Tools ..." />					
                <CsCompile Project="$(K9GitHubCommitStatusProject)" Configuration="$(K9Configuration)" />
                                
                <!-- UPDATE STATUS -->        
                <Spawn Exe="$(K9GitHubCommitStatusExecutable)" Arguments="---CREDENTIALS=$(RootDir)\Staging\github.k9.tmp ---REPO-OWNER=dotBunny ---REPO-NAME=NEXUS ---SHA-FILE=$(RootDir)/NEXUS/GIT_COMMIT_SHA ---STATE=$(GitHubTestState) ---CONTEXT=\"$(TestPackageLabel)\" ---DESCRIPTION=Successful ---URL=https://horde.dotbunny.com:5001/job/$(UE_HORDE_JOBID)" />	                            
            </Node>
        </Do>        
    </Agent>

    <Aggregate Name="TestPackage" Requires="$(GraphPrefix) $(ProjectName);$(TestPackageAggregate)"/>
     
     <Do If="'$(TestPackageLabel)' != ''" >
        <Label Category="Tests" Name="$(TestPackageLabel)" Requires="BuildAndTest $(ProjectName)" UgsBadge="$(TestPackageLabel)" />
     </Do>

</BuildGraph>